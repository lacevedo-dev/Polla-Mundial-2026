# ─────────────────────────────────────────────────────────────
# apps/web-corp — Portal Corporativo ZonaPronosticos
# Puerto de desarrollo: 3005  (npm run corp:dev)
#
# Puertos del sistema:
#   3005 → apps/web-corp   (B2B zonapronosticos.com + tenants)
# ─────────────────────────────────────────────────────────────

# URL del backend API
# Dev:  http://localhost:3004
# Prod: https://api-polla-coop.atencionesvirtuales.com.co
VITE_API_URL=http://localhost:3004

# Slug del tenant para simular un portal de empresa en desarrollo local.
# En producción NO se usa — el slug se detecta desde el hostname automáticamente.
#
# Ejemplos:
#   VITE_TENANT_SLUG=           → muestra la landing B2B (zonapronosticos.com)
#   VITE_TENANT_SLUG=coopcanapro → simula coopcanapro.zonapronosticos.com
VITE_TENANT_SLUG=

# Google reCAPTCHA v3 (site key pública).
# Debe corresponder al mismo dominio configurado en Google reCAPTCHA.
VITE_RECAPTCHA_SITE_KEY=
