# --- Base de datos corporativa independiente ---------------------------------
# Usar CORP_DATABASE_URL para no mezclar la BD corporativa con la BD principal.
# `localhost` solo aplica si MySQL corre en el mismo contenedor/host.
CORP_DATABASE_URL=mysql://u875522599_polla_corp:S0p0rt3%2A%2A26@srv1849.hstgr.io:3306/u875522599_polla_corp?connectionLimit=1&minimumIdle=1&acquireTimeout=30000
# Activar temporalmente para diagnosticar conexi�n directa MariaDB en logs de arranque.
CORP_DATABASE_STARTUP_PROBE=false
# Fallback de emergencia: permite usar DATABASE_URL si Dokploy no inyecta CORP_DATABASE_URL.
# Mantener false salvo diagn�stico temporal.
CORP_ALLOW_DATABASE_URL_FALLBACK=false

# ─── JWT ─────────────────────────────────────────────────────────────────────
# DEBE ser el mismo secret que el backend principal para que los tokens sean compatibles
JWT_SECRET=tu_jwt_secret_aqui

# ─── Servidor ─────────────────────────────────────────────────────────────────
PORT=3001
NODE_ENV=production

# ─── Comunicación interna con el backend principal ───────────────────────────
# URL del VPS principal para proxy de datos de fútbol
MAIN_API_URL=https://api.tupolla.com
# API key de servicio para autenticar llamadas internas
INTERNAL_API_KEY=clave_interna_secreta_compartida

# ─── Email (SMTP) ─────────────────────────────────────────────────────────────
SMTP_HOST=smtp.tuproveedor.com
SMTP_PORT=587
SMTP_USER=noreply@tucorp.com
SMTP_PASS=tu_smtp_password
SMTP_FROM=Polla Corporativa <noreply@tucorp.com>

# ─── Web Push Notifications ───────────────────────────────────────────────────
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:admin@tucorp.com

# ─── Email Encryption (para EmailProviderCryptoService) ──────────────────────
EMAIL_PROVIDER_ENCRYPTION_KEY=32_char_hex_key_aqui
# --- Email Dispatcher --------------------------------------------------------
# Desactivado por defecto en api-corp para evitar que el cron de emails del API
# principal golpee la BD corporativa cada 2 minutos. Habilitar solo si api-corp
# debe despachar emails directamente y la BD/SMTP est�n listos.
CORP_EMAIL_DISPATCHER_ENABLED=false
# Ejecuta sincronizacion completa unos segundos despues del arranque.
CORP_SYNC_ON_STARTUP=true

# ─── CORS ─────────────────────────────────────────────────────────────────────
# Lista separada por comas para todos los frontends autorizados.
CORP_CORS_ORIGINS=https://corp.tupolla.com,https://coopcanapro.zonapronosticos.com
# Compatibilidad con configuracion anterior de un solo frontend.
CORP_FRONTEND_URL=https://corp.tupolla.com
