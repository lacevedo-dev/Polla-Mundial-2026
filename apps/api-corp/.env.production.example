# Ejemplo de variables de entorno para producciГіn
# Copiar a .env en el servidor y ajustar valores

# в”Ђв”Ђв”Ђ Base de Datos Corporativa в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ
# Usar el host real de la BD. `localhost` solo aplica si MySQL corre en el mismo contenedor/host.
# Si el log muestra "Access denied for user ... @ '<IP>'", autorizar esa IP en MySQL/hosting
# o usar un host/usuario con permisos remotos.
CORP_DATABASE_URL="mysql://usuario:password@host:3306/polla_corp?connectionLimit=1&minimumIdle=0"
# Activar temporalmente para diagnosticar conexiуn directa MariaDB en logs de arranque.
CORP_DATABASE_STARTUP_PROBE=false
# Fallback de emergencia: permite usar DATABASE_URL si Dokploy no inyecta CORP_DATABASE_URL.
# Mantener false salvo diagnуstico temporal.
CORP_ALLOW_DATABASE_URL_FALLBACK=false

# в”Ђв”Ђв”Ђ API Principal (para sincronizaciГіn) в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ
MAIN_API_URL="https://api.pollamundial.com"
INTERNAL_API_KEY="CAMBIAR-POR-CLAVE-SECRETA-COMPARTIDA"

# в”Ђв”Ђв”Ђ AutenticaciГіn (compartida con API principal) в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ
JWT_SECRET="MISMO-SECRET-QUE-API-PRINCIPAL"

# в”Ђв”Ђв”Ђ Servidor в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ
PORT=3001
NODE_ENV=production
# --- CORS --------------------------------------------------------------------
# Lista separada por comas de frontends autorizados para consumir api-corp.
# En produccion NO usar "*"; agregar aqui cada dominio corporativo publicado.
CORP_CORS_ORIGINS="https://coopcanapro.zonapronosticos.com,https://pollacoopcanapro.atencionesvirtuales.com.co"
# Compatibilidad con configuracion anterior de un solo frontend.
CORP_FRONTEND_URL="https://pollacoopcanapro.atencionesvirtuales.com.co"

# в”Ђв”Ђв”Ђ Opcional: Avatares (si se habilita en el futuro) в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ
# AVATAR_UPLOAD_DIR=/app/uploads/avatars
# --- Email Dispatcher --------------------------------------------------------
# Desactivado por defecto en api-corp para evitar que el cron de emails del API
# principal golpee la BD corporativa cada 2 minutos. Habilitar solo si api-corp
# debe despachar emails directamente y la BD/SMTP estбn listos.
CORP_EMAIL_DISPATCHER_ENABLED=false
# Ejecuta sincronizacion completa unos segundos despues del arranque.
CORP_SYNC_ON_STARTUP=true
