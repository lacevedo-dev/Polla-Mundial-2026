// Schema Prisma para API Corporativo (BD independiente)
// Este schema contiene solo las tablas necesarias para el backend corporativo

generator client {
  provider = "prisma-client-js"
  output   = "../../../node_modules/@prisma/client-corp"
}

datasource db {
  provider = "mysql"
}

// ─── Usuarios (sincronizados desde API principal) ───────────────────────────

model User {
  id                 String         @id @default(cuid())
  name               String
  email              String
  username           String         @unique
  documentNumber     String         @unique @db.VarChar(64)
  phone              String?
  countryCode        String         @default("+57")
  avatar             String?
  birthDate          DateTime?
  passwordHash       String?
  mustChangePassword Boolean        @default(false)
  googleId           String?        @unique
  githubId           String?        @unique
  plan               Plan           @default(FREE)
  emailVerified      Boolean        @default(false)
  createdAt          DateTime       @default(now())
  updatedAt          DateTime       @updatedAt
  systemRole         SystemRole     @default(USER)
  status             UserStatus     @default(ACTIVE)
  
  // Tokens de autenticación
  verificationTokens VerificationToken[]
  passwordResetTokens PasswordResetToken[]

  // Relaciones corporativas
  tenantMemberships  TenantMember[]
  leagueMembers      LeagueMember[]
  predictions        Prediction[]
  notifications      Notification[]

  @@index([email])
  @@index([status])
  @@index([username])
}

// ─── Tokens de Autenticación ───────────────────────────────────────────────

model VerificationToken {
  id        String    @id @default(cuid())
  token     String    @unique
  userId    String
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
}

model PasswordResetToken {
  id        String    @id @default(cuid())
  token     String    @unique
  userId    String
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
}

enum UserStatus {
  ACTIVE
  INACTIVE
  SUSPENDED
  BANNED
}

enum SystemRole {
  USER
  ADMIN
  SUPERADMIN
}

enum Plan {
  FREE
  GOLD
  DIAMOND
}

// ─── Tenants Corporativos ───────────────────────────────────────────────────

model CorporateTenant {
  id             String               @id @default(cuid())
  slug           String               @unique
  name           String
  legalName      String?
  contactEmail   String
  status         TenantStatus         @default(PENDING_SETUP)
  planTier       TenantPlanTier       @default(STARTER)
  allowedDomains String?              @db.Text
  customDomain   String?              @unique
  ssoEnabled     Boolean              @default(false)
  ssoProvider    String?
  ssoConfig      String?              @db.LongText
  maxUsers       Int                  @default(50)
  maxLeagues     Int                  @default(3)
  createdAt      DateTime             @default(now())
  updatedAt      DateTime             @updatedAt
  
  branding       TenantBranding?
  config         TenantConfig?
  members        TenantMember[]
  leagues        League[]
  subscription   TenantSubscription?
  invitations    TenantInvitation[]

  @@index([slug])
  @@index([status])
  @@index([customDomain])
}

model TenantBranding {
  id                  String          @id @default(cuid())
  tenantId            String          @unique
  logoUrl             String?
  faviconUrl          String?
  primaryColor        String          @default("#16a34a")
  secondaryColor      String          @default("#15803d")
  accentColor         String          @default("#bbf7d0")
  fontFamily          String          @default("Inter")
  heroImageUrl        String?
  sidebarImageUrl     String?
  companyDisplayName  String?
  customCss           String?         @db.LongText
  emailHeaderHtml     String?         @db.Text
  emailFooterHtml     String?         @db.Text
  emailInviteTemplate String?         @db.Text
  createdAt           DateTime        @default(now())
  updatedAt           DateTime        @updatedAt
  tenant              CorporateTenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
}

model TenantConfig {
  id                     String          @id @default(cuid())
  tenantId               String          @unique
  enablePayments         Boolean         @default(true)
  enableAiInsights       Boolean         @default(false)
  enablePublicLeagues    Boolean         @default(false)
  enableUserSelfRegister Boolean         @default(false)
  requireInvitation      Boolean         @default(true)
  enableEmailNotif       Boolean         @default(true)
  enablePushNotif        Boolean         @default(true)
  enableStageFees        Boolean         @default(true)
  createdAt              DateTime        @default(now())
  updatedAt              DateTime        @updatedAt
  tenant                 CorporateTenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
}

model TenantMember {
  id         String             @id @default(cuid())
  tenantId   String
  userId     String
  role       TenantRole         @default(PLAYER)
  status     TenantMemberStatus @default(ACTIVE)
  invitedAt  DateTime           @default(now())
  joinedAt   DateTime?
  tenant     CorporateTenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  user       User               @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([tenantId, userId])
  @@index([tenantId])
  @@index([userId])
  @@index([status])
}

model TenantSubscription {
  id               String             @id @default(cuid())
  tenantId         String             @unique
  billingModel     TenantBillingModel @default(FLAT_MONTHLY)
  priceMonthly     Int                @default(0)
  priceSetup       Int                @default(0)
  currency         Currency           @default(COP)
  stripeSubId      String?
  status           String             @default("ACTIVE")
  currentPeriodEnd DateTime?
  createdAt        DateTime           @default(now())
  updatedAt        DateTime           @updatedAt
  tenant           CorporateTenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId])
}

model TenantInvitation {
  id          String          @id @default(cuid())
  tenantId    String
  email       String
  role        TenantRole      @default(PLAYER)
  token       String          @unique
  status      InviteStatus    @default(SENT)
  bulkBatchId String?
  sentAt      DateTime?
  resendCount Int             @default(0)
  expiresAt   DateTime?
  createdAt   DateTime        @default(now())
  tenant      CorporateTenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([tenantId, email])
  @@index([tenantId])
  @@index([token])
  @@index([status])
}

// ─── Pollas y Competencias ──────────────────────────────────────────────────

model League {
  id                     String          @id @default(cuid())
  name                   String
  description            String?         @db.Text
  code                   String          @unique
  privacy                Privacy         @default(PRIVATE)
  logo                   String?
  maxParticipants        Int             @default(10)
  includeBaseFee         Boolean         @default(true)
  baseFee                Int?
  includeStageFees       Boolean         @default(false)
  currency               Currency        @default(COP)
  adminFeePercent        Int             @default(10)
  plan                   Plan            @default(FREE)
  status                 LeagueStatus    @default(SETUP)
  closePredictionMinutes Int             @default(15)
  createdAt              DateTime        @default(now())
  updatedAt              DateTime        @updatedAt
  primaryTournamentId    String?
  tenantId               String?
  
  tenant                 CorporateTenant? @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  primaryTournament      Tournament?      @relation("LeaguePrimaryTournament", fields: [primaryTournamentId], references: [id])
  leagueMatches          LeagueMatch[]
  members                LeagueMember[]
  leagueTournaments      LeagueTournament[]
  predictions            Prediction[]
  scoringRules           ScoringRule[]

  @@index([code])
  @@index([tenantId])
  @@index([status])
  @@index([primaryTournamentId])
}

model LeagueMember {
  id        String       @id @default(cuid())
  leagueId  String
  userId    String
  role      MemberRole   @default(PLAYER)
  status    MemberStatus @default(PENDING)
  joinedAt  DateTime     @default(now())
  league    League       @relation(fields: [leagueId], references: [id], onDelete: Cascade)
  user      User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, leagueId])
  @@index([leagueId])
  @@index([userId])
}

model LeagueMatch {
  id       String   @id @default(cuid())
  leagueId String
  matchId  String
  active   Boolean  @default(true)
  addedAt  DateTime @default(now())
  addedBy  String?
  league   League   @relation(fields: [leagueId], references: [id], onDelete: Cascade)
  match    Match    @relation(fields: [matchId], references: [id], onDelete: Cascade)

  @@unique([leagueId, matchId])
  @@index([leagueId, active])
  @@index([matchId])
}

model LeagueTournament {
  id           String     @id @default(cuid())
  leagueId     String
  tournamentId String
  addedAt      DateTime   @default(now())
  league       League     @relation(fields: [leagueId], references: [id], onDelete: Cascade)
  tournament   Tournament @relation(fields: [tournamentId], references: [id], onDelete: Cascade)

  @@unique([leagueId, tournamentId])
  @@index([leagueId])
  @@index([tournamentId])
}

model ScoringRule {
  id                    String  @id @default(cuid())
  leagueId              String
  ruleType              ScoringType
  points                Int
  multiplier            Float   @default(1)
  appliesToPhase        Phase?
  description           String?
  active                Boolean @default(true)
  league                League  @relation(fields: [leagueId], references: [id], onDelete: Cascade)

  @@unique([leagueId, ruleType, appliesToPhase])
}

// ─── Pronósticos ─────────────────────────────────────────────────────────────

model Prediction {
  id            String   @id @default(cuid())
  userId        String
  matchId       String
  leagueId      String
  homeScore     Int
  awayScore     Int
  points        Float?
  pointDetail   String?  @db.LongText
  submittedAt   DateTime @default(now())
  updatedAt     DateTime @updatedAt
  advanceTeamId String?
  advanceTeam   Team?    @relation("AdvancePredictions", fields: [advanceTeamId], references: [id])
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  match         Match    @relation(fields: [matchId], references: [id], onDelete: Cascade)
  league        League   @relation(fields: [leagueId], references: [id], onDelete: Cascade)

  @@unique([userId, matchId, leagueId])
  @@index([leagueId, matchId])
  @@index([userId, leagueId])
  @@index([userId, submittedAt(sort: Desc)])
  @@index([matchId])
  @@index([advanceTeamId])
}

// ─── Notificaciones In-App ──────────────────────────────────────────────────

model Notification {
  id      String           @id @default(cuid())
  userId  String
  type    NotificationType
  title   String
  body    String           @db.Text
  data    String?          @db.LongText
  read    Boolean          @default(false)
  channel NotifChannel     @default(IN_APP)
  sentAt  DateTime         @default(now())
  user    User             @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, read])
  @@index([sentAt])
}

enum NotificationType {
  MATCH_REMINDER
  PREDICTION_CLOSED
  RESULT_PUBLISHED
  RANKING_CHANGE
  INVITE_RECEIVED
  PAYMENT_CONFIRMED
  LEAGUE_UPDATE
  GOAL_SCORED
}

enum NotifChannel {
  IN_APP
  PUSH
  EMAIL
}

// ─── Datos de Fútbol (sincronizados desde API principal) ────────────────────

model Tournament {
  id                  String             @id @default(cuid())
  name                String
  country             String?
  type                String             @default("KNOCKOUT")
  logoUrl             String?
  apiFootballLeagueId Int                @unique
  season              Int
  active              Boolean            @default(true)
  createdAt           DateTime           @default(now())
  updatedAt           DateTime           @updatedAt
  
  matches             Match[]
  leagueTournaments   LeagueTournament[]
  primaryLeagues      League[]           @relation("LeaguePrimaryTournament")

  @@index([apiFootballLeagueId])
  @@index([season])
}

model Team {
  id                 String       @id @default(cuid())
  name               String       @unique
  code               String       @unique
  group              String?
  flagUrl            String?
  shortCode          String?      @db.VarChar(8)
  apiFootballTeamId  Int?         @unique
  
  homeMatches        Match[]      @relation("HomeTeam")
  awayMatches        Match[]      @relation("AwayTeam")
  advancingInMatches Match[]      @relation("AdvancingTeam")
  advancePredictions Prediction[] @relation("AdvancePredictions")

  @@index([shortCode])
}

model Match {
  id                       String        @id @default(cuid())
  homeTeamId               String
  awayTeamId               String
  homeScore                Int?
  awayScore                Int?
  phase                    Phase
  group                    String?
  matchNumber              Int?
  venue                    String?
  matchDate                DateTime
  status                   MatchStatus   @default(SCHEDULED)
  createdAt                DateTime      @default(now())
  updatedAt                DateTime      @updatedAt
  externalId               String?       @unique
  lastSyncAt               DateTime?
  syncCount                Int           @default(0)
  round                    String?
  tournamentId             String?
  predictionReportSentAt   DateTime?
  advancingTeamId          String?
  resultNotificationSentAt DateTime?
  elapsed                  Int?
  statusShort              String?       @db.VarChar(8)
  eventsNoDataAt           DateTime?
  
  tournament               Tournament?   @relation(fields: [tournamentId], references: [id])
  homeTeam                 Team          @relation("HomeTeam", fields: [homeTeamId], references: [id])
  awayTeam                 Team          @relation("AwayTeam", fields: [awayTeamId], references: [id])
  advancingTeam            Team?         @relation("AdvancingTeam", fields: [advancingTeamId], references: [id])
  leagueMatches            LeagueMatch[]
  predictions              Prediction[]

  @@index([tournamentId])
  @@index([matchDate])
  @@index([status])
  @@index([phase])
  @@index([externalId])
  @@index([advancingTeamId])
}

// ─── Enums ───────────────────────────────────────────────────────────────────

enum TenantStatus {
  PENDING_SETUP
  ACTIVE
  SUSPENDED
  CANCELLED
}

enum TenantPlanTier {
  STARTER
  BUSINESS
  ENTERPRISE
}

enum TenantBillingModel {
  FLAT_MONTHLY
  PER_USER
  ANNUAL
  CUSTOM
}

enum TenantRole {
  OWNER
  ADMIN
  STAFF
  PLAYER
}

enum TenantMemberStatus {
  ACTIVE
  INACTIVE
  BANNED
}

enum InviteStatus {
  SENT
  ACCEPTED
  EXPIRED
  CANCELLED
}

enum Privacy {
  PUBLIC
  PRIVATE
}

enum MemberRole {
  ADMIN
  PLAYER
}

enum MemberStatus {
  PENDING
  PENDING_PAYMENT
  ACTIVE
  REJECTED
  BANNED
}

enum LeagueStatus {
  SETUP
  ACTIVE
  PAUSED
  FINISHED
  CANCELLED
}

enum MatchStatus {
  SCHEDULED
  LIVE
  FINISHED
  POSTPONED
  CANCELLED
}

enum Phase {
  GROUP
  ROUND_OF_32
  ROUND_OF_16
  QUARTER
  SEMI
  THIRD_PLACE
  FINAL
}

enum ScoringType {
  EXACT_SCORE
  CORRECT_DIFF
  CORRECT_WINNER
  UNIQUE_PREDICTION
  TEAM_GOALS
  PHASE_BONUS_R32
  PHASE_BONUS_R16
  PHASE_BONUS_QF
  PHASE_BONUS_SF
  PHASE_BONUS_FINAL
}

enum Currency {
  COP
  USD
  EUR
}

// ─── Email Queue (compartido con API principal) ─────────────────────────────

model EmailJob {
  id             String           @id @default(cuid())
  type           EmailJobType
  priority       EmailJobPriority
  status         EmailJobStatus   @default(PENDING)
  required       Boolean          @default(false)
  recipientEmail String           @db.VarChar(320)
  subject        String           @db.VarChar(255)
  html           String           @db.LongText
  text           String           @db.LongText
  dedupeKey      String           @unique
  matchId        String?
  leagueId       String?
  providerKey    String?
  scheduledAt    DateTime         @default(now())
  availableAt    DateTime         @default(now())
  lastAttemptAt  DateTime?
  attemptCount   Int              @default(0)
  sentAt         DateTime?
  lastError        String?          @db.Text
  attachmentsJson  String?          @db.LongText
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt

  @@index([status, availableAt])
  @@index([priority, scheduledAt])
  @@index([matchId])
  @@index([leagueId])
  @@index([providerKey])
}

model EmailBacklogAuditRun {
  id                         String                   @id @default(cuid())
  trigger                    EmailBacklogAuditTrigger
  mode                       EmailBacklogAuditMode
  status                     EmailBacklogAuditStatus  @default(RUNNING)
  startedAt                  DateTime                 @default(now())
  completedAt                DateTime?
  durationMs                 Int?
  inspectedCount             Int                      @default(0)
  actionableCount            Int                      @default(0)
  staleSendingCount          Int                      @default(0)
  exhaustedRetryCount        Int                      @default(0)
  transientWithinBudgetCount Int                      @default(0)
  sanitizedCount             Int                      @default(0)
  deferredCount              Int                      @default(0)
  failedCount                Int                      @default(0)
  droppedCount               Int                      @default(0)
  notActionedCount           Int                      @default(0)
  errorCount                 Int                      @default(0)
  summary                    String?                  @db.LongText
  errorMessage               String?                  @db.Text
  createdAt                  DateTime                 @default(now())
  updatedAt                  DateTime                 @updatedAt
}

enum EmailJobType {
  VERIFICATION
  MATCH_REMINDER
  PREDICTION_CLOSING
  PREDICTIONS_REPORT
  MATCH_RESULTS_REPORT
}

enum EmailJobPriority {
  HIGH
  MEDIUM
  LOW
}

enum EmailJobStatus {
  PENDING
  SENDING
  SENT
  FAILED
  DEFERRED
  DROPPED
}

enum EmailBacklogAuditTrigger {
  SCHEDULER
  MANUAL
  CLI
}

enum EmailBacklogAuditMode {
  AUDIT
  SANITIZE
}

enum EmailBacklogAuditStatus {
  RUNNING
  COMPLETED
  FAILED
  SKIPPED
}

// ─── Email Provider & Blacklist ───────────────────────────────────────────────

model EmailProviderUsage {
  id               String    @id @default(cuid())
  providerKey      String
  quotaWindowStart DateTime
  sentCount        Int       @default(0)
  blockedUntil     DateTime?
  lastError        String?   @db.Text
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  @@unique([providerKey, quotaWindowStart])
  @@index([providerKey, blockedUntil])
}

model EmailProviderAccount {
  id                      String    @id @default(cuid())
  key                     String    @unique
  name                    String    @db.VarChar(120)
  fromEmail               String    @db.VarChar(320)
  fromName                String?
  smtpHost                String    @db.VarChar(255)
  smtpPort                Int       @default(587)
  secure                  Boolean   @default(false)
  smtpUser                String?   @db.VarChar(320)
  smtpPassEncrypted       String?   @db.LongText
  dailyLimit              Int       @default(100)
  reservedHighPriority    Int       @default(60)
  maxRecipientsPerMessage Int       @default(100)
  maxEmailSizeMb          Int       @default(35)
  maxAttachmentSizeMb     Int       @default(25)
  active                  Boolean   @default(true)
  blockedUntil            DateTime?
  lastUsedAt              DateTime?
  lastError               String?   @db.Text
  deletedAt               DateTime?
  createdAt               DateTime  @default(now())
  updatedAt               DateTime  @updatedAt

  @@index([active, deletedAt])
  @@index([key, blockedUntil])
}

model EmailBlacklist {
  id           String               @id @default(cuid())
  email        String               @unique @db.VarChar(320)
  reason       EmailBlacklistReason @default(BOUNCE)
  failureCount Int                  @default(1)
  lastFailure  DateTime             @default(now())
  lastError    String?              @db.Text
  autoBlocked  Boolean              @default(true)
  blockedAt    DateTime             @default(now())
  blockedBy    String?
  notes        String?              @db.Text
  createdAt    DateTime             @default(now())
  updatedAt    DateTime             @updatedAt

  @@index([email])
  @@index([reason])
  @@index([autoBlocked])
}

enum EmailBlacklistReason {
  BOUNCE
  INVALID_ADDRESS
  SPAM_COMPLAINT
  MANUAL
  REPEATED_FAILURE
}
