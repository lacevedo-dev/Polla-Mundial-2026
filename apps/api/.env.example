# Use isolated non-production credentials whenever possible.
# Do NOT point local development to a production-limited database account silently.
# Loopback hosts like localhost / 127.0.0.1 / ::1 are only valid for local development.
DATABASE_URL="mariadb://app_user:app_password@127.0.0.1:3306/polla_dev"
PORT=3004
NODE_ENV=development
JWT_SECRET="replace-with-a-local-secret"
APP_URL="http://localhost:3004"
BOLD_API_KEY="optional-non-production-key"

# API-Football Configuration
API_FOOTBALL_KEY="your_api_football_key_here"
API_FOOTBALL_BASE_URL="https://v3.football.api-sports.io"
API_FOOTBALL_DAILY_LIMIT=100
MIN_SYNC_INTERVAL_MINUTES=5
MAX_SYNC_INTERVAL_MINUTES=30
TIMEZONE="America/Bogota"

# Twilio (WhatsApp + SMS) — opcional
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886
TWILIO_SMS_FROM=

# WhatsApp Web (whatsapp-web.js) — opcional
# Activa la publicación automática en grupos de WhatsApp.
# En producción (Docker/Dokploy) monta un volumen en /data/wwebjs_auth para que la sesión sobreviva redeploys:
#   Dokploy → Volumes → Host Path: /var/lib/dokploy/wwebjs/<nombre-app>  →  Container Path: /data/wwebjs_auth
WHATSAPP_WEB_ENABLED=false
WHATSAPP_SESSION_PATH=/data/wwebjs_auth

# VAPID (Push Web)
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_EMAIL=

# Google reCAPTCHA v3 para /auth/login.
# Para exigir token válido, configurar también VITE_RECAPTCHA_SITE_KEY en apps/web y activar RECAPTCHA_REQUIRED=true.
RECAPTCHA_SECRET_KEY=
RECAPTCHA_REQUIRED=false
RECAPTCHA_MIN_SCORE=0.5

# ─── Comunicación interna con el backend corporativo ─────────────────────────
# Debe coincidir exactamente con INTERNAL_API_KEY en apps/api-corp/.env
INTERNAL_API_KEY=
