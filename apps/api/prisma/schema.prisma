generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
}

model User {
  id                 String              @id @default(cuid())
  name               String
  email              String              @unique
  username           String              @unique
  phone              String?
  countryCode        String              @default("+57")
  avatar             String?
  birthDate          DateTime?
  passwordHash       String
  plan               Plan                @default(FREE)
  emailVerified      Boolean             @default(false)
  createdAt          DateTime            @default(now())
  updatedAt          DateTime            @updatedAt
  systemRole         SystemRole          @default(USER)
  auditLogs          AuditLog[]
  invitations        Invitation[]
  leagues            LeagueMember[]
  notifications      Notification[]
  orders             Order[]
  payments           Payment[]
  participationObligations ParticipationObligation[]
  predictions        Prediction[]
  verificationTokens VerificationToken[]
  aiUsageRecords     AiUsageRecord[]
  phaseBonuses       PhaseBonus[]
  pushSubscriptions  PushSubscription[]

  @@index([email])
  @@index([username])
}

model VerificationToken {
  id        String    @id @default(cuid())
  token     String    @unique
  userId    String
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
}

model League {
  id                     String              @id @default(cuid())
  name                   String
  description            String?             @db.Text
  code                   String              @unique
  privacy                Privacy             @default(PRIVATE)
  logo                   String?
  maxParticipants        Int                 @default(10)
  includeBaseFee         Boolean             @default(true)
  baseFee                Int?
  includeStageFees       Boolean             @default(false)
  currency               Currency            @default(COP)
  adminFeePercent        Int                 @default(10)
  plan                   Plan                @default(FREE)
  status                 LeagueStatus        @default(SETUP)
  closePredictionMinutes Int                 @default(15)
  primaryTournamentId    String?
  createdAt              DateTime            @default(now())
  updatedAt              DateTime            @updatedAt
  primaryTournament      Tournament?         @relation("LeaguePrimaryTournament", fields: [primaryTournamentId], references: [id])
  leagueTournaments      LeagueTournament[]
  auditLogs              AuditLog[]
  invitations            Invitation[]
  members                LeagueMember[]
  payments               Payment[]
  participationObligations ParticipationObligation[]
  predictions            Prediction[]
  distributions          PrizeDistribution[]
  scoringRules           ScoringRule[]
  stageFees              StageFee[]
  phaseBonuses           PhaseBonus[]

  @@index([code])
  @@index([status])
}

model LeagueMember {
  id       String       @id @default(cuid())
  userId   String
  leagueId String
  role     MemberRole   @default(PLAYER)
  status   MemberStatus @default(PENDING)
  joinedAt DateTime     @default(now())
  league   League       @relation(fields: [leagueId], references: [id], onDelete: Cascade)
  user     User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, leagueId])
  @@index([leagueId])
  @@index([userId])
}

model PrizeDistribution {
  id         String               @id @default(cuid())
  leagueId   String
  category   DistributionCategory
  position   Int
  label      String
  percentage Float
  active     Boolean              @default(true)
  league     League               @relation(fields: [leagueId], references: [id], onDelete: Cascade)

  @@unique([leagueId, category, position])
  @@index([leagueId])
}

model StageFee {
  id       String    @id @default(cuid())
  leagueId String
  type     StageType
  label    String
  amount   Int
  active   Boolean   @default(true)
  dueDate  DateTime?
  league   League    @relation(fields: [leagueId], references: [id], onDelete: Cascade)

  @@unique([leagueId, type, label])
  @@index([leagueId])
}

model ScoringRule {
  id             String      @id @default(cuid())
  leagueId       String
  ruleType       ScoringType
  points         Int
  multiplier     Float       @default(1)
  appliesToPhase Phase?
  description    String?
  active         Boolean     @default(true)
  league         League      @relation(fields: [leagueId], references: [id], onDelete: Cascade)

  @@unique([leagueId, ruleType, appliesToPhase])
}

model Tournament {
  id                  String   @id @default(cuid())
  name                String
  country             String?
  type                String   @default("KNOCKOUT")
  logoUrl             String?
  apiFootballLeagueId Int      @unique
  season              Int
  active              Boolean  @default(true)
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt
  matches             Match[]
  leagueTournaments   LeagueTournament[]
  primaryLeagues      League[]            @relation("LeaguePrimaryTournament")

  @@index([apiFootballLeagueId])
  @@index([season])
}

model LeagueTournament {
  id           String     @id @default(cuid())
  leagueId     String
  tournamentId String
  addedAt      DateTime   @default(now())
  league       League     @relation(fields: [leagueId], references: [id], onDelete: Cascade)
  tournament   Tournament @relation(fields: [tournamentId], references: [id], onDelete: Cascade)

  @@unique([leagueId, tournamentId])
  @@index([leagueId])
  @@index([tournamentId])
}

model Team {
  id                String  @id @default(cuid())
  name              String  @unique
  code              String  @unique
  group             String?
  flagUrl           String?
  shortCode         String? @db.VarChar(8)
  apiFootballTeamId Int?    @unique
  awayMatches       Match[] @relation("AwayTeam")
  homeMatches       Match[] @relation("HomeTeam")
  advancePredictions Prediction[] @relation("AdvancePredictions")
  advancingInMatches Match[]      @relation("AdvancingTeam")

  @@index([shortCode])
}

model Match {
  id          String            @id @default(cuid())
  homeTeamId  String
  awayTeamId  String
  homeScore   Int?
  awayScore   Int?
  phase       Phase
  group       String?
  matchNumber Int?
  venue       String?
  matchDate   DateTime
  status      MatchStatus       @default(SCHEDULED)
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt
  externalId              String?           @unique
  lastSyncAt              DateTime?
  syncCount               Int               @default(0)
  predictionReportSentAt       DateTime?
  resultNotificationSentAt     DateTime?
  advancingTeamId String?
  advancingTeam   Team?   @relation("AdvancingTeam", fields: [advancingTeamId], references: [id])
  tournamentId            String?
  round         String?
  syncLogs      FootballSyncLog[]
  tournament    Tournament?       @relation(fields: [tournamentId], references: [id])
  participationObligations ParticipationObligation[]
  awayTeam    Team              @relation("AwayTeam", fields: [awayTeamId], references: [id])
  homeTeam    Team              @relation("HomeTeam", fields: [homeTeamId], references: [id])
  predictions Prediction[]

  @@index([matchDate])
  @@index([status])
  @@index([phase])
  @@index([externalId])
  @@index([awayTeamId], map: "Match_awayTeamId_fkey")
  @@index([homeTeamId], map: "Match_homeTeamId_fkey")
  @@index([advancingTeamId])
}

model Prediction {
  id          String   @id @default(cuid())
  userId      String
  matchId     String
  leagueId    String
  homeScore   Int
  awayScore   Int
  points      Float?
  pointDetail String?  @db.LongText
  advanceTeamId String?
  advanceTeam   Team?   @relation("AdvancePredictions", fields: [advanceTeamId], references: [id])
  submittedAt DateTime @default(now())
  updatedAt   DateTime @updatedAt
  league      League   @relation(fields: [leagueId], references: [id])
  match       Match    @relation(fields: [matchId], references: [id])
  user        User     @relation(fields: [userId], references: [id])

  @@unique([userId, matchId, leagueId])
  @@index([leagueId, matchId])
  @@index([userId, leagueId])
  @@index([userId, submittedAt(sort: Desc)])
  @@index([matchId], map: "Prediction_matchId_fkey")
  @@index([advanceTeamId])
}

model Payment {
  id           String        @id @default(cuid())
  userId       String
  leagueId     String
  conceptId    String?
  conceptType  String?
  amount       Int
  method       PaymentMethod
  status       PaymentStatus @default(PENDING)
  verifiedBy   String?
  note         String?       @db.Text
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  league       League        @relation(fields: [leagueId], references: [id])
  user         User          @relation(fields: [userId], references: [id])
  transactions Transaction[]

  @@index([userId, leagueId])
  @@index([status])
  @@index([leagueId], map: "Payment_leagueId_fkey")
}

model Transaction {
  id          String   @id @default(cuid())
  paymentId   String
  gatewayRef  String?
  gatewayId   String?
  amount      Int
  currency    Currency @default(COP)
  status      String
  rawResponse String?  @db.LongText
  createdAt   DateTime @default(now())
  payment     Payment  @relation(fields: [paymentId], references: [id])

  @@index([gatewayRef])
  @@index([paymentId], map: "Transaction_paymentId_fkey")
}

model Invitation {
  id        String        @id @default(cuid())
  leagueId  String
  invitedBy String
  channel   InviteChannel
  recipient String
  status    InviteStatus  @default(SENT)
  token     String?       @unique
  expiresAt DateTime?
  createdAt DateTime      @default(now())
  inviter   User          @relation(fields: [invitedBy], references: [id])
  league    League        @relation(fields: [leagueId], references: [id], onDelete: Cascade)

  @@index([leagueId])
  @@index([token])
  @@index([invitedBy], map: "Invitation_invitedBy_fkey")
}

model Notification {
  id      String           @id @default(cuid())
  userId  String
  type    NotificationType
  title   String
  body    String           @db.Text
  data    String?          @db.LongText
  read    Boolean          @default(false)
  channel NotifChannel     @default(IN_APP)
  sentAt  DateTime         @default(now())
  user    User             @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, read])
  @@index([sentAt])
}

model ParticipationObligation {
  id                String               @id @default(cuid())
  userId            String
  leagueId          String
  matchId           String?
  category          ParticipationCategory
  referenceId       String?
  referenceLabel    String
  source            ParticipationSource  @default(PREDICTION)
  unitAmount        Int
  multiplier        Int                  @default(1)
  totalAmount       Int
  currency          Currency             @default(COP)
  status            ParticipationStatus  @default(PENDING_PAYMENT)
  deadlineAt        DateTime
  orderId           String?
  paymentId         String?
  reminder30SentAt  DateTime?
  reminder10SentAt  DateTime?
  paidAt            DateTime?
  expiredAt         DateTime?
  cancelledAt       DateTime?
  createdAt         DateTime             @default(now())
  updatedAt         DateTime             @updatedAt
  league            League               @relation(fields: [leagueId], references: [id], onDelete: Cascade)
  match             Match?               @relation(fields: [matchId], references: [id], onDelete: Cascade)
  user              User                 @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, status])
  @@index([leagueId, category, status])
  @@index([deadlineAt, status])
  @@index([matchId])
  @@index([orderId])
}

model Order {
  id                    String      @id @default(cuid())
  userId                String
  amount                Decimal     @db.Decimal(10, 2)
  currency              String      @default("USD")
  status                OrderStatus @default(PENDING)
  stripeSessionId       String?     @unique
  stripePaymentIntentId String?     @unique
  items                 String      @db.LongText
  createdAt             DateTime    @default(now())
  updatedAt             DateTime    @updatedAt
  user                  User        @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([status])
}

model AuditLog {
  id        String   @id @default(cuid())
  leagueId  String?
  userId    String
  action    String
  detail    String?  @db.LongText
  createdAt DateTime @default(now())
  league    League?  @relation(fields: [leagueId], references: [id])
  user      User     @relation(fields: [userId], references: [id])

  @@index([leagueId, createdAt])
  @@index([userId], map: "AuditLog_userId_fkey")
}

model SystemConfig {
  key       String   @id
  value     String   @db.LongText
  updatedAt DateTime @updatedAt
}

model ApiFootballRequest {
  id             String   @id @default(cuid())
  date           DateTime @default(now())
  endpoint       String
  params         String?  @db.LongText
  responseStatus Int
  matchesFetched Int      @default(0)
  externalId     String?
  responseBody   String?  @db.LongText
  createdAt      DateTime @default(now())

  @@index([date])
  @@index([externalId])
}

model DailySyncPlan {
  id              String       @id @default(cuid())
  date            String       @unique
  totalMatches    Int
  intervalMinutes Int
  requestsUsed    Int          @default(0)
  requestsBudget  Int
  strategy        SyncStrategy
  lastSyncAt      DateTime?
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt

  @@index([date])
}

model FootballSyncLog {
  id             String        @id @default(cuid())
  type           SyncLogType
  status         SyncLogStatus
  matchId        String?
  externalId     String?
  message        String        @db.Text
  details        String?       @db.LongText
  requestsUsed   Int           @default(0)
  matchesUpdated Int           @default(0)
  duration       Int?
  error          String?       @db.LongText
  triggeredBy    String?
  createdAt      DateTime      @default(now())
  match          Match?        @relation(fields: [matchId], references: [id])

  @@index([type, status])
  @@index([createdAt])
  @@index([matchId])
}

model FootballSyncConfig {
  id                     String   @id @default(cuid())
  enabled                Boolean  @default(true)
  minSyncInterval        Int      @default(5)
  maxSyncInterval        Int      @default(30)
  dailyRequestLimit      Int      @default(100)
  alertThreshold         Int      @default(90)
  autoSyncEnabled        Boolean  @default(true)
  peakHoursSyncEnabled   Boolean  @default(true)
  emergencyModeThreshold Int      @default(10)
  notifyOnError          Boolean  @default(true)
  notifyOnLimit          Boolean  @default(true)
  updatedBy              String?
  updatedAt              DateTime @updatedAt
  createdAt              DateTime @default(now())

  @@index([updatedAt])
}

model FootballSyncAlert {
  id         String         @id @default(cuid())
  type       SyncAlertType
  severity   SyncAlertLevel
  message    String         @db.Text
  details    String?        @db.LongText
  resolved   Boolean        @default(false)
  resolvedBy String?
  resolvedAt DateTime?
  createdAt  DateTime       @default(now())

  @@index([resolved, severity])
  @@index([createdAt])
}

enum SystemRole {
  USER
  ADMIN
  SUPERADMIN
}

enum Plan {
  FREE
  GOLD
  DIAMOND
}

enum Privacy {
  PUBLIC
  PRIVATE
}

enum Currency {
  COP
  MXN
  ARS
  USD
  CLP
  PEN
  BRL
}

enum Phase {
  GROUP
  ROUND_OF_32
  ROUND_OF_16
  QUARTER
  SEMI
  THIRD_PLACE
  FINAL
}

enum MemberRole {
  ADMIN
  PLAYER
}

enum MemberStatus {
  PENDING
  PENDING_PAYMENT
  ACTIVE
  REJECTED
  BANNED
}

enum ParticipationCategory {
  PRINCIPAL
  MATCH
  GROUP
  ROUND
  PHASE
}

enum ParticipationSource {
  PREDICTION
  INVITATION
  ADMIN
  SYSTEM
}

enum ParticipationStatus {
  PENDING_PAYMENT
  PAID
  EXPIRED
  CANCELLED
}

enum MatchStatus {
  SCHEDULED
  LIVE
  FINISHED
  POSTPONED
  CANCELLED
}

enum PaymentMethod {
  CASH
  TRANSFER
  NEQUI
  DAVIPLATA
  BANCOLOMBIA
  GATEWAY
}

enum PaymentStatus {
  PENDING
  REVIEW
  CONFIRMED
  REJECTED
}

enum LeagueStatus {
  SETUP
  ACTIVE
  PAUSED
  FINISHED
  CANCELLED
}

enum StageType {
  MATCH
  ROUND
  PHASE
}

enum ScoringType {
  EXACT_SCORE
  CORRECT_DIFF
  CORRECT_WINNER
  UNIQUE_PREDICTION
  TEAM_GOALS
  PHASE_BONUS_R32
  PHASE_BONUS_R16
  PHASE_BONUS_QF
  PHASE_BONUS_SF
  PHASE_BONUS_FINAL
}

enum DistributionCategory {
  GENERAL
  MATCH
  ROUND
  PHASE
}

enum InviteChannel {
  EMAIL
  WHATSAPP
  SMS
  LINK
}

enum InviteStatus {
  SENT
  CLICKED
  ACCEPTED
  EXPIRED
}

enum OrderStatus {
  PENDING
  COMPLETED
  FAILED
  REFUNDED
}

enum NotificationType {
  MATCH_REMINDER
  PREDICTION_CLOSED
  RESULT_PUBLISHED
  RANKING_CHANGE
  INVITE_RECEIVED
  PAYMENT_CONFIRMED
  LEAGUE_UPDATE
}

enum NotifChannel {
  IN_APP
  PUSH
  EMAIL
  SMS
  WHATSAPP
}

enum SyncStrategy {
  AGGRESSIVE
  BALANCED
  CONSERVATIVE
  EMERGENCY
}

enum SyncLogType {
  MANUAL_SYNC
  AUTO_SYNC
  CRON_SYNC
  MATCH_SYNC
  DAILY_PLAN
  EMERGENCY_SYNC
  TEST_SYNC
}

enum SyncLogStatus {
  SUCCESS
  PARTIAL
  FAILED
  SKIPPED
}

enum SyncAlertType {
  RATE_LIMIT_WARNING
  RATE_LIMIT_EXCEEDED
  SYNC_FAILURE
  API_ERROR
  CONFIGURATION_CHANGE
  EMERGENCY_MODE
  NO_MATCHES_UPDATED
}

enum SyncAlertLevel {
  INFO
  WARNING
  ERROR
  CRITICAL
}

model PhaseBonus {
  id        String   @id @default(cuid())
  userId    String
  leagueId  String
  phase     Phase
  points    Float
  awardedAt DateTime @default(now())

  user   User   @relation(fields: [userId], references: [id])
  league League @relation(fields: [leagueId], references: [id])

  @@unique([userId, leagueId, phase])
  @@index([leagueId])
  @@index([userId])
}

model AiUsageRecord {
  id               String   @id @default(cuid())
  userId           String
  leagueId         String?
  matchId          String?
  feature          String
  creditsUsed      Int      @default(1)
  requestData      String?  @db.LongText
  responseData     String?  @db.LongText
  insightGenerated Boolean  @default(false)
  clientInfo       String?  @db.Text
  createdAt        DateTime @default(now())
  user             User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt(sort: Desc)])
  @@index([leagueId, createdAt(sort: Desc)])
  @@index([feature, createdAt(sort: Desc)])
  @@index([createdAt(sort: Desc)])
}

model PushSubscription {
  id        String   @id @default(cuid())
  userId    String
  endpoint  String   @db.Text
  p256dh    String   @db.Text
  auth      String   @db.Text
  userAgent String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model UserAiCredits {
  userId        String   @id
  plan          Plan
  totalCredits  Int
  usedCredits   Int      @default(0)
  lastResetAt   DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([plan])
}
