generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
}

model User {
  id                       String                    @id @default(cuid())
  name                     String
  email                    String                    @unique
  username                 String                    @unique
  phone                    String?
  countryCode              String                    @default("+57")
  avatar                   String?
  birthDate                DateTime?
  passwordHash             String
  plan                     Plan                      @default(FREE)
  emailVerified            Boolean                   @default(false)
  createdAt                DateTime                  @default(now())
  updatedAt                DateTime                  @updatedAt
  systemRole               SystemRole                @default(USER)
  status                   UserStatus                @default(ACTIVE)
  aiUsageRecords           AiUsageRecord[]
  auditLogs                AuditLog[]
  invitations              Invitation[]
  leagues                  LeagueMember[]
  notifications            Notification[]
  orders                   Order[]
  participationObligations ParticipationObligation[]
  payments                 Payment[]
  phaseBonuses             PhaseBonus[]
  predictions              Prediction[]
  pushSubscriptions        PushSubscription[]
  verificationTokens       VerificationToken[]

  @@index([email])
  @@index([status])
  @@index([username])
}

model VerificationToken {
  id        String    @id @default(cuid())
  token     String    @unique
  userId    String
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
}

model League {
  id                       String                    @id @default(cuid())
  name                     String
  description              String?                   @db.Text
  code                     String                    @unique
  privacy                  Privacy                   @default(PRIVATE)
  logo                     String?
  maxParticipants          Int                       @default(10)
  includeBaseFee           Boolean                   @default(true)
  baseFee                  Int?
  includeStageFees         Boolean                   @default(false)
  currency                 Currency                  @default(COP)
  adminFeePercent          Int                       @default(10)
  plan                     Plan                      @default(FREE)
  status                   LeagueStatus              @default(SETUP)
  closePredictionMinutes   Int                       @default(15)
  createdAt                DateTime                  @default(now())
  updatedAt                DateTime                  @updatedAt
  primaryTournamentId      String?
  auditLogs                AuditLog[]
  automationRuns           AutomationRun[]
  invitations              Invitation[]
  primaryTournament        Tournament?               @relation("LeaguePrimaryTournament", fields: [primaryTournamentId], references: [id])
  leagueMatches            LeagueMatch[]
  members                  LeagueMember[]
  leagueTournaments        LeagueTournament[]
  participationObligations ParticipationObligation[]
  payments                 Payment[]
  phaseBonuses             PhaseBonus[]
  predictions              Prediction[]
  distributions            PrizeDistribution[]
  scoringRules             ScoringRule[]
  stageFees                StageFee[]

  @@index([code])
  @@index([status])
  @@index([primaryTournamentId])
}

model LeagueMember {
  id       String       @id @default(cuid())
  userId   String
  leagueId String
  role     MemberRole   @default(PLAYER)
  status   MemberStatus @default(PENDING)
  joinedAt DateTime     @default(now())
  league   League       @relation(fields: [leagueId], references: [id], onDelete: Cascade)
  user     User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, leagueId])
  @@index([leagueId])
  @@index([userId])
}

model PrizeDistribution {
  id         String               @id @default(cuid())
  leagueId   String
  category   DistributionCategory
  position   Int
  label      String
  percentage Float
  active     Boolean              @default(true)
  league     League               @relation(fields: [leagueId], references: [id], onDelete: Cascade)

  @@unique([leagueId, category, position])
  @@index([leagueId])
}

model StageFee {
  id       String    @id @default(cuid())
  leagueId String
  type     StageType
  label    String
  amount   Int
  active   Boolean   @default(true)
  dueDate  DateTime?
  league   League    @relation(fields: [leagueId], references: [id], onDelete: Cascade)

  @@unique([leagueId, type, label])
  @@index([leagueId])
}

model ScoringRule {
  id             String      @id @default(cuid())
  leagueId       String
  ruleType       ScoringType
  points         Int
  multiplier     Float       @default(1)
  appliesToPhase Phase?
  description    String?
  active         Boolean     @default(true)
  league         League      @relation(fields: [leagueId], references: [id], onDelete: Cascade)

  @@unique([leagueId, ruleType, appliesToPhase])
}

model Tournament {
  id                  String             @id @default(cuid())
  name                String
  country             String?
  type                String             @default("KNOCKOUT")
  logoUrl             String?
  apiFootballLeagueId Int                @unique
  season              Int
  active              Boolean            @default(true)
  createdAt           DateTime           @default(now())
  updatedAt           DateTime           @updatedAt
  primaryLeagues      League[]           @relation("LeaguePrimaryTournament")
  leagueTournaments   LeagueTournament[]
  matches             Match[]

  @@index([apiFootballLeagueId])
  @@index([season])
}

model LeagueTournament {
  id           String     @id @default(cuid())
  leagueId     String
  tournamentId String
  addedAt      DateTime   @default(now())
  league       League     @relation(fields: [leagueId], references: [id], onDelete: Cascade)
  tournament   Tournament @relation(fields: [tournamentId], references: [id], onDelete: Cascade)

  @@unique([leagueId, tournamentId])
  @@index([leagueId])
  @@index([tournamentId])
}

model LeagueMatch {
  id       String   @id @default(cuid())
  leagueId String
  matchId  String
  active   Boolean  @default(true)
  addedAt  DateTime @default(now())
  addedBy  String?
  league   League   @relation(fields: [leagueId], references: [id], onDelete: Cascade)
  match    Match    @relation(fields: [matchId], references: [id], onDelete: Cascade)

  @@unique([leagueId, matchId])
  @@index([leagueId, active])
  @@index([matchId])
}

model Team {
  id                 String       @id @default(cuid())
  name               String       @unique
  code               String       @unique
  group              String?
  flagUrl            String?
  shortCode          String?      @db.VarChar(8)
  apiFootballTeamId  Int?         @unique
  advancingInMatches Match[]      @relation("AdvancingTeam")
  awayMatches        Match[]      @relation("AwayTeam")
  homeMatches        Match[]      @relation("HomeTeam")
  advancePredictions Prediction[] @relation("AdvancePredictions")

  @@index([shortCode])
}

model Match {
  id                       String                    @id @default(cuid())
  homeTeamId               String
  awayTeamId               String
  homeScore                Int?
  awayScore                Int?
  phase                    Phase
  group                    String?
  matchNumber              Int?
  venue                    String?
  matchDate                DateTime
  status                   MatchStatus               @default(SCHEDULED)
  createdAt                DateTime                  @default(now())
  updatedAt                DateTime                  @updatedAt
  externalId               String?                   @unique
  lastSyncAt               DateTime?
  syncCount                Int                       @default(0)
  round                    String?
  tournamentId             String?
  predictionReportSentAt   DateTime?
  advancingTeamId          String?
  resultNotificationSentAt DateTime?
  elapsed                  Int?
  statusShort              String?                   @db.VarChar(8)
  eventsNoDataAt           DateTime?
  automationRuns           AutomationRun[]
  syncLogs                 FootballSyncLog[]
  leagueMatches            LeagueMatch[]
  advancingTeam            Team?                     @relation("AdvancingTeam", fields: [advancingTeamId], references: [id])
  awayTeam                 Team                      @relation("AwayTeam", fields: [awayTeamId], references: [id])
  homeTeam                 Team                      @relation("HomeTeam", fields: [homeTeamId], references: [id])
  tournament               Tournament?               @relation(fields: [tournamentId], references: [id])
  events                   MatchEvent[]
  participationObligations ParticipationObligation[]
  predictions              Prediction[]

  @@index([matchDate])
  @@index([status])
  @@index([phase])
  @@index([externalId])
  @@index([awayTeamId], map: "Match_awayTeamId_fkey")
  @@index([homeTeamId], map: "Match_homeTeamId_fkey")
  @@index([advancingTeamId])
  @@index([tournamentId], map: "Match_tournamentId_fkey")
}

model MatchEvent {
  id         String   @id @default(cuid())
  matchId    String
  teamId     String?
  playerName String?
  assistName String?
  type       String
  detail     String?
  minute     Int
  extraMin   Int?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  match      Match    @relation(fields: [matchId], references: [id], onDelete: Cascade)

  @@unique([matchId, type, playerName, minute])
  @@index([matchId])
}

model Prediction {
  id            String   @id @default(cuid())
  userId        String
  matchId       String
  leagueId      String
  homeScore     Int
  awayScore     Int
  points        Float?
  pointDetail   String?  @db.LongText
  submittedAt   DateTime @default(now())
  updatedAt     DateTime @updatedAt
  advanceTeamId String?
  advanceTeam   Team?    @relation("AdvancePredictions", fields: [advanceTeamId], references: [id])
  league        League   @relation(fields: [leagueId], references: [id])
  match         Match    @relation(fields: [matchId], references: [id])
  user          User     @relation(fields: [userId], references: [id])

  @@unique([userId, matchId, leagueId])
  @@index([leagueId, matchId])
  @@index([userId, leagueId])
  @@index([userId, submittedAt(sort: Desc)])
  @@index([matchId], map: "Prediction_matchId_fkey")
  @@index([advanceTeamId])
}

model Payment {
  id           String        @id @default(cuid())
  userId       String
  leagueId     String
  conceptId    String?
  conceptType  String?
  amount       Int
  method       PaymentMethod
  status       PaymentStatus @default(PENDING)
  verifiedBy   String?
  note         String?       @db.Text
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  league       League        @relation(fields: [leagueId], references: [id])
  user         User          @relation(fields: [userId], references: [id])
  transactions Transaction[]

  @@index([userId, leagueId])
  @@index([status])
  @@index([leagueId], map: "Payment_leagueId_fkey")
}

model Transaction {
  id          String   @id @default(cuid())
  paymentId   String
  gatewayRef  String?
  gatewayId   String?
  amount      Int
  currency    Currency @default(COP)
  status      String
  rawResponse String?  @db.LongText
  createdAt   DateTime @default(now())
  payment     Payment  @relation(fields: [paymentId], references: [id])

  @@index([gatewayRef])
  @@index([paymentId], map: "Transaction_paymentId_fkey")
}

model Invitation {
  id        String        @id @default(cuid())
  leagueId  String
  invitedBy String
  channel   InviteChannel
  recipient String
  status    InviteStatus  @default(SENT)
  token     String?       @unique
  expiresAt DateTime?
  createdAt DateTime      @default(now())
  inviter   User          @relation(fields: [invitedBy], references: [id])
  league    League        @relation(fields: [leagueId], references: [id], onDelete: Cascade)

  @@index([leagueId])
  @@index([token])
  @@index([invitedBy], map: "Invitation_invitedBy_fkey")
}

model Notification {
  id      String           @id @default(cuid())
  userId  String
  type    NotificationType
  title   String
  body    String           @db.Text
  data    String?          @db.LongText
  read    Boolean          @default(false)
  channel NotifChannel     @default(IN_APP)
  sentAt  DateTime         @default(now())
  user    User             @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, read])
  @@index([sentAt])
}

model ParticipationObligation {
  id               String                @id @default(cuid())
  userId           String
  leagueId         String
  matchId          String?
  category         ParticipationCategory
  referenceId      String?
  referenceLabel   String
  source           ParticipationSource   @default(PREDICTION)
  unitAmount       Int
  multiplier       Int                   @default(1)
  totalAmount      Int
  currency         Currency              @default(COP)
  status           ParticipationStatus   @default(PENDING_PAYMENT)
  deadlineAt       DateTime
  orderId          String?
  paymentId        String?
  reminder30SentAt DateTime?
  reminder10SentAt DateTime?
  paidAt           DateTime?
  expiredAt        DateTime?
  cancelledAt      DateTime?
  createdAt        DateTime              @default(now())
  updatedAt        DateTime              @updatedAt
  league           League                @relation(fields: [leagueId], references: [id], onDelete: Cascade)
  match            Match?                @relation(fields: [matchId], references: [id], onDelete: Cascade)
  user             User                  @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, status])
  @@index([leagueId, category, status])
  @@index([deadlineAt, status])
  @@index([matchId])
  @@index([orderId])
}

model Order {
  id                    String      @id @default(cuid())
  userId                String
  amount                Decimal     @db.Decimal(10, 2)
  currency              String      @default("USD")
  status                OrderStatus @default(PENDING)
  stripeSessionId       String?     @unique
  stripePaymentIntentId String?     @unique
  items                 String      @db.LongText
  createdAt             DateTime    @default(now())
  updatedAt             DateTime    @updatedAt
  user                  User        @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([status])
}

model AuditLog {
  id        String   @id @default(cuid())
  leagueId  String?
  userId    String
  action    String
  detail    String?  @db.LongText
  createdAt DateTime @default(now())
  league    League?  @relation(fields: [leagueId], references: [id])
  user      User     @relation(fields: [userId], references: [id])

  @@index([leagueId, createdAt])
  @@index([userId], map: "AuditLog_userId_fkey")
}

model SystemConfig {
  key       String   @id
  value     String   @db.LongText
  updatedAt DateTime @updatedAt
}

model ApiFootballRequest {
  id             String   @id @default(cuid())
  date           DateTime @default(now())
  endpoint       String
  params         String?  @db.LongText
  responseStatus Int
  matchesFetched Int      @default(0)
  createdAt      DateTime @default(now())
  externalId     String?
  responseBody   String?  @db.LongText

  @@index([date])
  @@index([externalId])
}

model DailySyncPlan {
  id              String       @id @default(cuid())
  date            String       @unique
  totalMatches    Int
  intervalMinutes Int
  requestsUsed    Int          @default(0)
  requestsBudget  Int
  strategy        SyncStrategy
  lastSyncAt      DateTime?
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt

  @@index([date])
}

model FootballSyncLog {
  id             String        @id @default(cuid())
  type           SyncLogType
  status         SyncLogStatus
  matchId        String?
  externalId     String?
  message        String        @db.Text
  details        String?       @db.LongText
  requestsUsed   Int           @default(0)
  matchesUpdated Int           @default(0)
  duration       Int?
  error          String?       @db.LongText
  triggeredBy    String?
  createdAt      DateTime      @default(now())
  match          Match?        @relation(fields: [matchId], references: [id])

  @@index([type, status])
  @@index([createdAt])
  @@index([matchId])
}

model FootballSyncConfig {
  id                     String   @id @default(cuid())
  enabled                Boolean  @default(true)
  minSyncInterval        Int      @default(5)
  maxSyncInterval        Int      @default(30)
  dailyRequestLimit      Int      @default(100)
  alertThreshold         Int      @default(90)
  autoSyncEnabled        Boolean  @default(true)
  peakHoursSyncEnabled   Boolean  @default(true)
  emergencyModeThreshold Int      @default(10)
  notifyOnError          Boolean  @default(true)
  notifyOnLimit          Boolean  @default(true)
  updatedBy              String?
  updatedAt              DateTime @updatedAt
  createdAt              DateTime @default(now())
  eventSyncEnabled       Boolean  @default(false)

  @@index([updatedAt])
}

model FootballSyncAlert {
  id         String         @id @default(cuid())
  type       SyncAlertType
  severity   SyncAlertLevel
  message    String         @db.Text
  details    String?        @db.LongText
  resolved   Boolean        @default(false)
  resolvedBy String?
  resolvedAt DateTime?
  createdAt  DateTime       @default(now())

  @@index([resolved, severity])
  @@index([createdAt])
}

model AutomationRun {
  id             String               @id @default(cuid())
  correlationId  String?
  step           AutomationStep
  status         AutomationRunStatus
  trigger        AutomationRunTrigger @default(SCHEDULER)
  matchId        String
  leagueId       String?
  scheduledAt    DateTime?
  startedAt      DateTime
  finishedAt     DateTime?
  summary        String?              @db.Text
  errorMessage   String?              @db.Text
  details        String?              @db.LongText
  audienceCount  Int?
  deliveredCount Int?
  failedCount    Int?
  warningCount   Int?
  createdAt      DateTime             @default(now())
  updatedAt      DateTime             @updatedAt
  league         League?              @relation(fields: [leagueId], references: [id])
  match          Match                @relation(fields: [matchId], references: [id], onDelete: Cascade)

  @@index([matchId, step, startedAt])
  @@index([leagueId, step, startedAt])
  @@index([status, startedAt])
  @@index([trigger, startedAt])
  @@index([scheduledAt])
  @@index([correlationId])
}

model PhaseBonus {
  id        String   @id @default(cuid())
  userId    String
  leagueId  String
  phase     Phase
  points    Float
  awardedAt DateTime @default(now())
  league    League   @relation(fields: [leagueId], references: [id])
  user      User     @relation(fields: [userId], references: [id])

  @@unique([userId, leagueId, phase])
  @@index([leagueId])
  @@index([userId])
}

model AiUsageRecord {
  id               String   @id @default(cuid())
  userId           String
  leagueId         String?
  matchId          String?
  feature          String
  creditsUsed      Int      @default(1)
  requestData      String?  @db.LongText
  responseData     String?  @db.LongText
  insightGenerated Boolean  @default(false)
  clientInfo       String?  @db.Text
  createdAt        DateTime @default(now())
  user             User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt(sort: Desc)])
  @@index([leagueId, createdAt(sort: Desc)])
  @@index([feature, createdAt(sort: Desc)])
  @@index([createdAt(sort: Desc)])
}

model PushSubscription {
  id        String   @id @default(cuid())
  userId    String
  endpoint  String   @db.Text
  p256dh    String   @db.Text
  auth      String   @db.Text
  userAgent String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model UserAiCredits {
  userId       String   @id
  plan         Plan
  totalCredits Int
  usedCredits  Int      @default(0)
  lastResetAt  DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([plan])
}

model EmailJob {
  id             String           @id @default(cuid())
  type           EmailJobType
  priority       EmailJobPriority
  status         EmailJobStatus   @default(PENDING)
  required       Boolean          @default(false)
  recipientEmail String           @db.VarChar(320)
  subject        String           @db.VarChar(255)
  html           String           @db.LongText
  text           String           @db.LongText
  dedupeKey      String           @unique
  matchId        String?
  leagueId       String?
  providerKey    String?
  scheduledAt    DateTime         @default(now())
  availableAt    DateTime         @default(now())
  lastAttemptAt  DateTime?
  attemptCount   Int              @default(0)
  sentAt         DateTime?
  lastError      String?          @db.Text
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt

  @@index([status, availableAt])
  @@index([priority, scheduledAt])
  @@index([matchId])
  @@index([leagueId])
  @@index([providerKey])
}

model EmailProviderUsage {
  id               String    @id @default(cuid())
  providerKey      String
  quotaWindowStart DateTime
  sentCount        Int       @default(0)
  blockedUntil     DateTime?
  lastError        String?   @db.Text
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  @@unique([providerKey, quotaWindowStart])
  @@index([providerKey, blockedUntil])
}

model EmailProviderAccount {
  id                      String    @id @default(cuid())
  key                     String    @unique
  name                    String    @db.VarChar(120)
  fromEmail               String    @db.VarChar(320)
  fromName                String?
  smtpHost                String    @db.VarChar(255)
  smtpPort                Int       @default(587)
  secure                  Boolean   @default(false)
  smtpUser                String?   @db.VarChar(320)
  smtpPassEncrypted       String?   @db.LongText
  dailyLimit              Int       @default(100)
  reservedHighPriority    Int       @default(60)
  maxRecipientsPerMessage Int       @default(100)
  maxEmailSizeMb          Int       @default(35)
  maxAttachmentSizeMb     Int       @default(25)
  active                  Boolean   @default(true)
  blockedUntil            DateTime?
  lastUsedAt              DateTime?
  lastError               String?   @db.Text
  deletedAt               DateTime?
  createdAt               DateTime  @default(now())
  updatedAt               DateTime  @updatedAt

  @@index([active, deletedAt])
  @@index([key, blockedUntil])
}

model EmailBlacklist {
  id           String               @id @default(cuid())
  email        String               @unique @db.VarChar(320)
  reason       EmailBlacklistReason @default(BOUNCE)
  failureCount Int                  @default(1)
  lastFailure  DateTime             @default(now())
  lastError    String?              @db.Text
  autoBlocked  Boolean              @default(true)
  blockedAt    DateTime             @default(now())
  blockedBy    String?
  notes        String?              @db.Text
  createdAt    DateTime             @default(now())
  updatedAt    DateTime             @updatedAt

  @@index([email])
  @@index([reason])
  @@index([autoBlocked])
}

model EmailBacklogAuditRun {
  id                         String                   @id @default(cuid())
  trigger                    EmailBacklogAuditTrigger
  mode                       EmailBacklogAuditMode
  status                     EmailBacklogAuditStatus  @default(RUNNING)
  startedAt                  DateTime                 @default(now())
  completedAt                DateTime?
  durationMs                 Int?
  inspectedCount             Int                      @default(0)
  actionableCount            Int                      @default(0)
  staleSendingCount          Int                      @default(0)
  exhaustedRetryCount        Int                      @default(0)
  transientWithinBudgetCount Int                      @default(0)
  sanitizedCount             Int                      @default(0)
  deferredCount              Int                      @default(0)
  failedCount                Int                      @default(0)
  droppedCount               Int                      @default(0)
  notActionedCount           Int                      @default(0)
  errorCount                 Int                      @default(0)
  summary                    String?                  @db.LongText
  errorMessage               String?                  @db.Text
  createdAt                  DateTime                 @default(now())
  updatedAt                  DateTime                 @updatedAt

  @@index([startedAt])
  @@index([status, startedAt])
  @@index([trigger, startedAt])
}

enum SystemRole {
  USER
  ADMIN
  SUPERADMIN
}

enum UserStatus {
  ACTIVE
  INACTIVE
}

enum Plan {
  FREE
  GOLD
  DIAMOND
}

enum Privacy {
  PUBLIC
  PRIVATE
}

enum Currency {
  COP
  MXN
  ARS
  USD
  CLP
  PEN
  BRL
}

enum Phase {
  GROUP
  ROUND_OF_32
  ROUND_OF_16
  QUARTER
  SEMI
  THIRD_PLACE
  FINAL
}

enum MemberRole {
  ADMIN
  PLAYER
}

enum MemberStatus {
  PENDING
  PENDING_PAYMENT
  ACTIVE
  REJECTED
  BANNED
}

enum ParticipationCategory {
  PRINCIPAL
  MATCH
  GROUP
  ROUND
  PHASE
}

enum ParticipationSource {
  PREDICTION
  INVITATION
  ADMIN
  SYSTEM
}

enum ParticipationStatus {
  PENDING_PAYMENT
  PAID
  EXPIRED
  CANCELLED
}

enum MatchStatus {
  SCHEDULED
  LIVE
  FINISHED
  POSTPONED
  CANCELLED
}

enum PaymentMethod {
  CASH
  TRANSFER
  NEQUI
  DAVIPLATA
  BANCOLOMBIA
  GATEWAY
}

enum PaymentStatus {
  PENDING
  REVIEW
  CONFIRMED
  REJECTED
}

enum LeagueStatus {
  SETUP
  ACTIVE
  PAUSED
  FINISHED
  CANCELLED
}

enum StageType {
  MATCH
  ROUND
  PHASE
}

enum ScoringType {
  EXACT_SCORE
  CORRECT_DIFF
  CORRECT_WINNER
  UNIQUE_PREDICTION
  TEAM_GOALS
  PHASE_BONUS_R32
  PHASE_BONUS_R16
  PHASE_BONUS_QF
  PHASE_BONUS_SF
  PHASE_BONUS_FINAL
}

enum DistributionCategory {
  GENERAL
  MATCH
  ROUND
  PHASE
}

enum InviteChannel {
  EMAIL
  WHATSAPP
  SMS
  LINK
}

enum InviteStatus {
  SENT
  CLICKED
  ACCEPTED
  EXPIRED
}

enum OrderStatus {
